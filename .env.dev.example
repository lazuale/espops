# Тестовый стенд EspoCRM.
# Скопировать в .env.dev и при необходимости поправить значения перед запуском.
# Реальный .env.dev в Git не добавлять.

ESPOCRM_IMAGE=espocrm/espocrm:9.3.8-apache-trixie
MARIADB_IMAGE=mariadb:11.4.11-noble

# Адрес и порты внутреннего сервера.
ESPOCRM_BIND_IP=10.0.2.7
ESPOCRM_HTTP_PORT=8080
ESPOCRM_WEBSOCKET_PORT=8083
ESPOCRM_SITE_URL=http://10.0.2.7:8080
ESPOCRM_WEB_SOCKET_URL=ws://10.0.2.7:8083

# База данных.
# Для простого переноса рабочего стенда в тестовый имя БД, пользователь и пароль БД
# должны совпадать с рабочим стендом.
ESPOCRM_DATABASE_NAME=espocrm
ESPOCRM_DATABASE_USER=espocrm

# Пароли держать в одинарных кавычках.
ESPOCRM_DATABASE_PASSWORD='CHANGE_ME_DEV_DB_SECRET'
MARIADB_ROOT_PASSWORD='CHANGE_ME_DEV_ROOT_SECRET'

# Администратор создаётся только при первой установке на пустой том Docker.
ESPOCRM_ADMIN_USERNAME=admin
ESPOCRM_ADMIN_PASSWORD='CHANGE_ME_DEV_ADMIN_SECRET'
