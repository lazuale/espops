# Тестовый стенд EspoCRM.
# Скопировать в .env.dev и при необходимости поправить пароли.
# Реальный .env.dev в Git не добавлять.

ESPOCRM_IMAGE=espocrm/espocrm:9.3.7-apache-trixie
MARIADB_IMAGE=mariadb:11.4.11-noble

ESPOCRM_HTTP_PORT=8080
ESPOCRM_WEBSOCKET_PORT=8083
ESPOCRM_SITE_URL=http://localhost:8080
ESPOCRM_WEB_SOCKET_URL=ws://localhost:8083

ESPOCRM_DATABASE_NAME=espocrm
ESPOCRM_DATABASE_USER=espocrm
ESPOCRM_DATABASE_PASSWORD='dev_database_password'
MARIADB_ROOT_PASSWORD='dev_root_password'

ESPOCRM_ADMIN_USERNAME=admin
ESPOCRM_ADMIN_PASSWORD='dev_admin_password'
